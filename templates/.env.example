# Copy this file to `.env` and adjust as needed.
# Taskfile auto-detects host UID/GID via `id`, so PUID/PGID overrides are
# usually unnecessary. Uncomment only when you need to pin specific values.
# PUID=1000
# PGID=1000

# Python version used by the base image entrypoint.
PYTHON_VERSION=3.12

# Override the compose project name (defaults to the current directory).
# COMPOSE_PROJECT_NAME=my-project
